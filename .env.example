# Server
PORT=3000
NODE_ENV=development

# API Keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DASHSCOPE_API_KEY=...
KIMI_API_KEY=...
ZHIPU_API_KEY=...
ERNIE_API_KEY=...

# Redis (optional - uses memory cache if not available)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL=3600

# RAG Settings
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RAG_TOP_K=5

# Frontend
VITE_API_URL=http://localhost:3000
