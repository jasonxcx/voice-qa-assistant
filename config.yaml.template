# LLM 大语言模型配置
llm:
  # 临时配置（运行时会被当前 provider 覆盖）
  mode: "openai" # 可选: "openai" / "ollama" / "lmstudio"
  model: "qwen3.5-plus"
  base_url: "https://coding.dashscope.aliyuncs.com/v1"
  api_key: "YOUR_DASHSCOPE_API_KEY"

  # 生成参数
  generation:
    temperature: 0.3
    max_completion_tokens: 500
    max_completion_tokens_stream: 1000
    reasoning_effort: "none"  # 可选: "none", "minimal", "low", "medium", "high", "xhigh"

  # 提示词配置（从文件读取）
  prompts:
    base: llm_system_prompt_base.txt

  # 持久 provider 配置
  provider:
    lmstudio:
      base_url: http://127.0.0.1:1234
      model: qwen3.5-4b
    ollama:
      base_url: http://127.0.0.1:11434
      model: qwen2.5:7b
    openai:
      api_key: sk-xxxxxxx
      base_url: https://coding.dashscope.aliyuncs.com/v1
      model: qwen3.5-plus

# STT 配置
stt:
  model: medium
  # STT 转录提示词（帮助识别面试场景的专业术语）
  initial_prompt: "面试场景，包含技术术语如 Java, Python, MySQL, Redis, Kafka, Docker, Kubernetes, 微服务，分布式系统，算法，数据结构等。"
  # STT 热词（提高识别准确率）
  hotwords: "Java Python MySQL Redis Kafka Docker Kubernetes Spring TensorFlow PyTorch 微服务 分布式 算法 数据结构 多线程 并发 API SDK HTTP TCP IP"
  local:
    # 为空时使用 stt.model 自动下载；填写后优先使用本地目录
    model_path: ""
    compute_type: float16
    device: cuda
    language: zh
  download:
    # 留空则使用默认 Hugging Face
    mirror: https://hf-mirror.com/
    # 可选，自定义下载缓存目录；留空则使用 huggingface 默认缓存
    cache_dir: ""
  auto:
    # 自动分句模式：RMS 音量阈值（越大越不敏感）
    volume_threshold: 0.015
    # 起始语音阈值 = max(volume_threshold, 噪声底 * voice_ratio)
    voice_ratio: 3.0
    # 语音保持阈值 = max(噪声底 * silence_ratio, volume_threshold * 0.6)
    silence_ratio: 1.8
    # 噪声底 EMA 更新系数（越大越灵敏）
    noise_alpha: 0.08
    # 连续静音达到该时长后判定为一句结束
    pause_seconds: 0.8
    # 最短句长，小于 2 秒不触发转录
    min_sentence_seconds: 2.0
    # 最长句长兜底，超过后强制切分，避免跨句粘连
    max_sentence_seconds: 8.0
    # 从"静音中"恢复为"有声中"所需的连续有声块数量（抗噪声尖峰）
    resume_voice_chunks: 2

# UI 配置
ui:
  overlay_height: 500
  overlay_width_ratio: 0.85
  overlay_border_radius: 12
  font_size: 12
  transcription:
    # True=手动点"开始监听"；False=自动分句转录
    manual_mode: true
